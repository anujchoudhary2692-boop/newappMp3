# Copy to .env and fill in values before production deploy
# cp .env.example .env

# ── MongoDB (docker-compose.prod.yml) ─────────────────────────────
MONGO_ROOT_USER=mediaface
MONGO_ROOT_PASSWORD=change-me-strong-password

# ── Backend API security (required in production) ─────────────────
# Generate: openssl rand -hex 24
# Keep the SAME value in:
#   - Render env API_KEY
#   - mobile/src/production.config.ts → PRODUCTION_API_KEY
#   - Docker build arg VITE_API_KEY / render.yaml dockerBuildArgs
API_KEY=c25daa68d397e64c4a7694a53d5c1f4dccfdfee444451287
REQUIRE_API_KEY=true

# Comma-separated origins for CORS (your app domain only)
CORS_ALLOWED_ORIGINS=https://newappmp3.onrender.com

# Optional admin console login (Settings → users). Leave empty to disable bootstrap admin.
ADMIN_USERNAME=
ADMIN_PASSWORD=
REQUIRE_AUTH=false

# ── Ports ─────────────────────────────────────────────────────────
BACKEND_PORT=8080

# ── HTTPS (optional Caddy profile) ────────────────────────────────
DOMAIN=api.yourdomain.com

# ── Local dev (scripts/start-backend.sh) ──────────────────────────
MONGODB_URI=mongodb://localhost:27019/mediaface
SPRING_PROFILES_ACTIVE=

# ── Free catalogs (no account) ────────────────────────────────────
# Openverse (CC audio incl. Jamendo/Freesound) + ccMixter are default.
# Internet Archive downloads are often blocked from cloud IPs (401/403).
# Optional Jamendo direct API: JAMENDO_CLIENT_ID=

# ── Mobile: PRODUCTION_API_KEY must match API_KEY above ───────────
